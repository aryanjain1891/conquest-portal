# -------- Django core --------
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# Set to False in production.
DJANGO_DEBUG=True

# Comma-separated list of hostnames this backend will answer on.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Full frontend origins allowed to hit the API. Comma-separated, include scheme.
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173

# -------- Postgres (used by docker-compose) --------
POSTGRES_DB=conquest_portal
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Leave as 'db' when running via docker-compose. Set to 'localhost' for bare-metal Postgres.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -------- Email --------
# dummy   → drop all outbound mail (demo default, nothing sent)
# console → print mail to backend stdout (dev debugging)
# ses     → real AWS SES send (needs AWS creds below + verified sender)
EMAIL_MODE=dummy

# Only needed when EMAIL_MODE=ses.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=ap-south-1
DEFAULT_FROM_EMAIL=no-reply@your-domain.example

# -------- Sentry (optional) --------
# Leave blank to disable Sentry.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0
