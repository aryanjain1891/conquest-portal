# Base URL of the backend API (e.g. https://api.example.com). No trailing slash.
VITE_API_BASE_URL=http://localhost:8000

# Marketing/brochure site used for footer/nav links (alumni, about, etc.). Leave blank to disable.
VITE_MARKETING_SITE_URL=

# Public contact email shown in the footer.
VITE_CONTACT_EMAIL=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable analytics.
VITE_GA_MEASUREMENT_ID=

# Google OAuth 2.0 web client ID used by the Sign in with Google button.
VITE_GOOGLE_OAUTH_CLIENT_ID=your-value-here.apps.googleusercontent.com

# Firebase web app config (used for Firebase Storage file uploads).
VITE_FIREBASE_API_KEY=your-value-here
VITE_FIREBASE_AUTH_DOMAIN=your-value-here.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-value-here
VITE_FIREBASE_STORAGE_BUCKET=your-value-here.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-value-here
VITE_FIREBASE_APP_ID=your-value-here
VITE_FIREBASE_MEASUREMENT_ID=your-value-here
